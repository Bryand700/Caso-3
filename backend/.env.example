# Modo inmediatamente ejecutable, con una base SQLite local.
GATHEL_DEMO_MODE=true
GATHEL_API_HOST=127.0.0.1
GATHEL_API_PORT=5080
GATHEL_DB_POOL_SIZE=3

# Para conectar SQL Server, cambie GATHEL_DEMO_MODE=false y configure:
# GATHEL_DATABASE_URL=mssql+pyodbc://usuario:clave@localhost:1433/Gathel?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
