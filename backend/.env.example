# Copie este archivo como .env en la raíz del repositorio.
# Docker conecta al SQL Server instalado en Windows mediante host.docker.internal.
GATHEL_DEMO_MODE=false
GATHEL_API_HOST=0.0.0.0
GATHEL_API_PORT=5080
GATHEL_DB_POOL_SIZE=3

GATHEL_SQL_HOST=host.docker.internal
GATHEL_SQL_PORT=1433
GATHEL_SQL_DATABASE=Gathel
GATHEL_SQL_USER=gathel_app
GATHEL_SQL_PASSWORD=123
GATHEL_SQL_DRIVER=ODBC Driver 18 for SQL Server

# Alternativa avanzada: una URL completa tiene prioridad sobre las variables anteriores.
# GATHEL_DATABASE_URL=mssql+pyodbc://usuario:clave@host.docker.internal:1433/Gathel?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes
